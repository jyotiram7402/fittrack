# ---- Supabase (required) ----
# Project URL + anon key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the browser / NEXT_PUBLIC_*.
# Used by server actions, route handlers, and the seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for auth redirects + OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Optional ----
# Error tracking (leave blank to disable)
SENTRY_DSN=

# Seed script — the first admin account it should create/promote
SEED_ADMIN_EMAIL=jkamble@southco.com
SEED_ADMIN_PASSWORD=change-me-now
